# ============================================================
# career-agent environment variables
# Copy this file to .env and adjust as needed.
# .env is gitignored — never commit your real .env.
# ============================================================

# ----- Model tiering -----
# Claude model used for bulk job discovery + scoring (cheap, fast).
SEARCH_MODEL=haiku

# Claude model used for resume tailoring + cover letter generation.
# Set to opus for the highest-quality resumes (slower, costs more tokens).
TAILOR_MODEL=sonnet

# Claude model used for browser-based form-filling during applications.
APPLY_MODEL=sonnet

# ----- Automation -----
# When set to 1, the web UI automatically queues the tailor→apply pipeline
# once you approve a job from the Jobs tab (still pauses at both human gates).
CAREER_AUTO_APPLY=1

# ----- Server -----
# Port the web UI server listens on.
CAREER_UI_PORT=8377

# ----- CLI -----
# Path (or name) of the Claude Code CLI binary.
CLAUDE_BIN=claude
